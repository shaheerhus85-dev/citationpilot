DATABASE_URL=sqlite:///./app.db
JWT_SECRET=your-secret-key-minimum-32-characters-long-required
JWT_ALGORITHM=HS256
FRONTEND_URL=http://localhost:3000
STRICT_ENV_VALIDATION=false

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
CONTACT_RECEIVER_EMAIL=shaheerhus85@gmail.com

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=CitationPilot

TEMP_EMAIL_PROVIDER=mail_tm
MANUAL_QUEUE_ENABLED=true
STORE_FAILURE_SCREENSHOTS=true
MAX_SUBMISSION_RETRIES=3

ENABLE_BACKGROUND_WORKERS=true
WORKER_BATCH_SIZE=5
WORKER_INTERVAL_SECONDS=60
EMAIL_POLL_INTERVAL_SECONDS=120
EMAIL_MAX_FETCH_PER_CYCLE=40

ENVIRONMENT=development
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_AUTH_MAX_REQUESTS=30
RATE_LIMIT_CONTACT_MAX_REQUESTS=10
DEBUG=false
